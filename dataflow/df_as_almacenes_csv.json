{
	"name": "df_as_almacenes_csv",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "as_almacenes_csv",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "silver_as_almacenes",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          almacen_id as string,",
				"          nombre as string,",
				"          municipio as string,",
				"          departamento as string,",
				"          direccion as string,",
				"          capacidad_m3 as string,",
				"          estado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"source1 derive(almacen_id = toInteger(almacen_id),",
				"          nombre = trim(nombre),",
				"          municipio = trim(municipio),",
				"          departamento = trim(upper(departamento)),",
				"          direccion = trim(direccion),",
				"          capacidad_m3 = toDecimal(trim(capacidad_m3)),",
				"          estado = iif(isNull(estado) || trim(estado)=='', 'Desconocido', trim(estado))) ~> derivedColumn1",
				"derivedColumn1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          almacen_id as integer,",
				"          nombre as string,",
				"          municipio as string,",
				"          departamento as string,",
				"          direccion as string,",
				"          capacidad_m3 as decimal(10,2),",
				"          estado as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          almacen_id,",
				"          nombre,",
				"          municipio,",
				"          departamento,",
				"          direccion,",
				"          capacidad_m3,",
				"          estado",
				"     )) ~> sink1"
			]
		}
	}
}