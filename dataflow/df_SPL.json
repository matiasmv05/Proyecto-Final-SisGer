			"scriptLines": [
				"source(output(",
				"          afiliacion_id as string,",
				"          ci_beneficiaria as string,",
				"          empleador_id as string,",
				"          caja_id as string,",
				"          fecha_afiliacion as string,",
				"          nro_matricula as string,",
				"          tipo_subsidio as string,",
				"          estado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"source(output(",
				"          asignacion_id as string,",
				"          afiliacion_id as string,",
				"          mes as string,",
				"          gestion as string,",
				"          monto_bs as string,",
				"          monto_productos as string,",
				"          monto_carnes as string,",
				"          estado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source2",
				"source(output(",
				"          ID as string,",
				"          Nombre as string,",
				"          Sigla as string,",
				"          Tipo as string,",
				"          Estado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source3",
				"source(output(",
				"          certificado_id as string,",
				"          afiliacion_id as string,",
				"          fecha_emision as string,",
				"          semana_gestacion as string,",
				"          fecha_probable_parto as string,",
				"          medico_responsable as string,",
				"          estado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source4",
				"source(output(",
				"          empleador_id as string,",
				"          nit as string,",
				"          razon_social as string,",
				"          tipo as string,",
				"          nro_patronal as string,",
				"          municipio as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source5",
				"source(output(",
				"          entrega_ag_id as string,",
				"          asignacion_id as string,",
				"          ci_beneficiaria as string,",
				"          fecha_entrega as string,",
				"          productos as string,",
				"          lote as string,",
				"          peso_kg as string,",
				"          punto_entrega as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source6",
				"source(output(",
				"          entrega_super_id as string,",
				"          asignacion_id as string,",
				"          ci_beneficiaria as string,",
				"          supermercado_id as string,",
				"          fecha_retiro as string,",
				"          tipo_carne as string,",
				"          cantidad_kg as string,",
				"          monto_bs as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source7",
				"source(output(",
				"          ID as string,",
				"          Cadena as string,",
				"          Sucursal as string,",
				"          Municipio as string,",
				"          {Dirección} as string,",
				"          Estado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source8",
				"source1 derive(ci_beneficiaria = upper(trim(regexReplace(ci_beneficiaria, '[^a-zA-Z0-9]', ''))),",
				"          fecha_afiliacion = toDate(trim(fecha_afiliacion), 'yyyy-MM-dd'),",
				"          nro_matricula = upper(trim(nro_matricula)),",
				"          tipo_subsidio = iif(like(lower(trim(tipo_subsidio)), '%prenatal%'), 'Prenatal',   iif(like(lower(trim(tipo_subsidio)), '%lactancia%'), 'Lactancia',     initCap(lower(trim(tipo_subsidio)))   ) ),",
				"          estado = iif(like(lower(trim(estado)), '%completada%'), 'Completada',   iif(like(lower(trim(estado)), '%inactiva%'), 'Inactiva',     iif(like(lower(trim(estado)), '%activa%'), 'Activa',       initCap(lower(trim(estado)))     )   ) ),",
				"          caja_id = toInteger(caja_id)) ~> derivedColumn1",
				"source2 derive(estado = upper(trim(estado)),",
				"          monto_bs = round(toFloat(monto_bs), 2),",
				"          gestion = trim(gestion)) ~> derivedColumn2",
				"derivedColumn2 derive(estado = iif(isNull(estado) || trim(estado) == '', 'NO ESPECIFICADO', upper(trim(estado))),",
				"          monto_bs = toDecimal(monto_bs),",
				"          monto_productos = toDecimal(monto_productos),",
				"          monto_carnes = toDecimal(monto_carnes)) ~> derivedColumn3",
				"derivedColumn5 derive(estado = iif(isNull(trim(estado)) || trim(estado) == '', 'SIN_ESTADO', upper(trim(estado))),",
				"          mes = toInteger(mes)) ~> derivedColumn4",
				"derivedColumn3 derive(estado = upper(trim(estado))) ~> derivedColumn5",
				"source4 derive(fecha_emision = toDate(fecha_emision, 'yyyy-MM-dd'),",
				"          semana_gestacion = iif(isNull(semana_gestacion) || toString(semana_gestacion) == '', toInteger(null()), toInteger(semana_gestacion)),",
				"          fecha_probable_parto = iif(isNull(fecha_probable_parto) || trim(fecha_probable_parto) == '', toDate(null()), toDate(fecha_probable_parto, 'yyyy-MM-dd')),",
				"          medico_responsable = trim(medico_responsable),",
				"          estado = upper(trim(estado))) ~> derivedColumn7",
				"source5 derive(nit = trim(nit),",
				"          razon_social = trim(razon_social),",
				"          tipo = upper(trim(tipo)),",
				"          nro_patronal = upper(trim(nro_patronal)),",
				"          municipio = trim(municipio)) ~> derivedColumn8",
				"source6 derive(ci_beneficiaria = upper(trim(replace(ci_beneficiaria, '-', ''))),",
				"          fecha_entrega = iif(isNull(fecha_entrega) || trim(fecha_entrega) == '', toDate(null()),   iif(locate('/', fecha_entrega) > 0,     toDate(fecha_entrega, 'dd/MM/yyyy'),     iif(toInteger(left(trim(fecha_entrega), 4)) > 31,       toDate(fecha_entrega, 'yyyy-MM-dd'),       toDate(fecha_entrega, 'dd-MM-yyyy')))),",
				"          productos = trim(regexReplace(productos, '  +', ' ')),",
				"          lote = upper(trim(lote)),",
				"          peso_kg = toDecimal(peso_kg),",
				"          punto_entrega = upper(trim(regexReplace(punto_entrega, '  +', ' ')))) ~> derivedColumn9",
				"source7 derive(ci_beneficiaria = upper(trim(regexReplace(regexReplace(ci_beneficiaria, '^[a-zA-Z]+', ''), '-', ''))),",
				"          fecha_retiro = iif(isNull(fecha_retiro) || trim(fecha_retiro) == '', toDate(null()),   iif(locate('/', fecha_retiro) > 0,     iif(toInteger(left(trim(fecha_retiro), 2)) > 12,       toDate(fecha_retiro, 'dd/MM/yyyy'),       toDate(fecha_retiro, 'MM/dd/yyyy')),     iif(length(trim(fecha_retiro)) == 10 && toInteger(left(trim(fecha_retiro), 2)) <= 31 && toInteger(substring(trim(fecha_retiro), 4, 2)) <= 12,       toDate(fecha_retiro, 'dd-MM-yyyy'),       toDate(fecha_retiro, 'yyyy-MM-dd')))),",
				"          tipo_carne = upper(trim(tipo_carne)),",
				"          cantidad_kg = iif(isNull(cantidad_kg) || toString(cantidad_kg) == '', toDecimal(null()), toDecimal(cantidad_kg)),",
				"          monto_bs = iif(isNull(monto_bs) || toString(monto_bs) == '', toDecimal(null()), toDecimal(monto_bs)),",
				"          supermercado_id = toInteger(supermercado_id)) ~> derivedColumn10",
				"source8 derive(Cadena = trim(Cadena),",
				"          Sucursal = trim(Sucursal),",
				"          Municipio = trim(Municipio),",
				"          {Dirección} = trim({Dirección}),",
				"          Estado = upper(trim(Estado)),",
				"          ID = toInteger(ID)) ~> derivedColumn11",
				"source3 derive(ID = toInteger(ID),",
				"          Nombre = trim(Nombre),",
				"          Sigla = trim(Sigla),",
				"          Tipo = trim(Tipo),",
				"          Estado = trim(Estado)) ~> derivedColumn12",
				"derivedColumn1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          afiliacion_id as string,",
				"          ci_beneficiaria as string,",
				"          empleador_id as string,",
				"          caja_id as integer,",
				"          fecha_afiliacion as date,",
				"          nro_matricula as string,",
				"          tipo_subsidio as string,",
				"          estado as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          afiliacion_id,",
				"          ci_beneficiaria,",
				"          empleador_id,",
				"          caja_id,",
				"          fecha_afiliacion,",
				"          nro_matricula,",
				"          tipo_subsidio,",
				"          estado",
				"     )) ~> sink1",
				"derivedColumn4 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          asignacion_id as string,",
				"          afiliacion_id as string,",
				"          mes as integer,",
				"          gestion as string,",
				"          monto_bs as decimal(10,2),",
				"          monto_productos as decimal(10,2),",
				"          monto_carnes as decimal(10,2),",
				"          estado as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          asignacion_id,",
				"          afiliacion_id,",
				"          mes,",
				"          gestion,",
				"          monto_bs,",
				"          monto_productos,",
				"          monto_carnes,",
				"          estado",
				"     )) ~> sink2",
				"derivedColumn12 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          caja_id as integer,",
				"          nombre as string,",
				"          sigla as string,",
				"          tipo as string,",
				"          estado as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          caja_id = ID,",
				"          nombre = Nombre,",
				"          sigla = Sigla,",
				"          tipo = Tipo,",
				"          estado = Estado",
				"     )) ~> sink3",
				"derivedColumn7 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          certificado_id as string,",
				"          afiliacion_id as string,",
				"          fecha_emision as date,",
				"          semana_gestacion as integer,",
				"          fecha_probable_parto as date,",
				"          medico_responsable as string,",
				"          estado as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          certificado_id,",
				"          afiliacion_id,",
				"          fecha_emision,",
				"          semana_gestacion,",
				"          fecha_probable_parto,",
				"          medico_responsable,",
				"          estado",
				"     )) ~> sink4",
				"derivedColumn8 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          empleador_id as string,",
				"          nit as string,",
				"          razon_social as string,",
				"          tipo as string,",
				"          nro_patronal as string,",
				"          municipio as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          empleador_id,",
				"          nit,",
				"          razon_social,",
				"          tipo,",
				"          nro_patronal,",
				"          municipio",
				"     )) ~> sink5",
				"derivedColumn9 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          entrega_ag_id as string,",
				"          asignacion_id as string,",
				"          ci_beneficiaria as string,",
				"          fecha_entrega as date,",
				"          productos as string,",
				"          lote as string,",
				"          peso_kg as decimal(8,2),",
				"          punto_entrega as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          entrega_ag_id,",
				"          asignacion_id,",
				"          ci_beneficiaria,",
				"          fecha_entrega,",
				"          productos,",
				"          lote,",
				"          peso_kg,",
				"          punto_entrega",
				"     )) ~> sink6",
				"derivedColumn10 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          entrega_super_id as string,",
				"          asignacion_id as string,",
				"          ci_beneficiaria as string,",
				"          supermercado_id as integer,",
				"          fecha_retiro as date,",
				"          tipo_carne as string,",
				"          cantidad_kg as decimal(8,2),",
				"          monto_bs as decimal(10,2)",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          entrega_super_id,",
				"          asignacion_id,",
				"          ci_beneficiaria,",
				"          supermercado_id,",
				"          fecha_retiro,",
				"          tipo_carne,",
				"          cantidad_kg,",
				"          monto_bs",
				"     )) ~> sink7",
				"derivedColumn11 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          supermercado_id as integer,",
				"          cadena as string,",
				"          sucursal as string,",
				"          municipio as string,",
				"          direccion as string,",
				"          estado as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          cadena = Cadena,",
				"          sucursal = Sucursal,",
				"          municipio = Municipio,",
				"          estado = Estado",
				"     )) ~> sink8"
			]
		}
	}
}