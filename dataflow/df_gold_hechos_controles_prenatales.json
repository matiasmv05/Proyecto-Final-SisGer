{
	"name": "df_gold_hechos_controles_prenatales",
	"properties": {
		"folder": {
			"name": "gold"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "silver_bja_controles_prenatales",
						"type": "DatasetReference"
					},
					"name": "controlesprenatales"
				},
				{
					"dataset": {
						"referenceName": "gold_dim_beneficiaria",
						"type": "DatasetReference"
					},
					"name": "dimbeneficiaria"
				},
				{
					"dataset": {
						"referenceName": "gold_dim_establecimiento",
						"type": "DatasetReference"
					},
					"name": "dimestablecimiento"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "gold_hechos_controles_prenatales",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "lookup1"
				},
				{
					"name": "lookup2"
				},
				{
					"name": "derivedColumn1"
				},
				{
					"name": "select1"
				},
				{
					"name": "derivedColumn2"
				}
			],
			"scriptLines": [
				"source(output(",
				"          control_id as string,",
				"          ci_beneficiaria as string,",
				"          establecimiento_id as string,",
				"          fecha_control as date,",
				"          sistema_key as integer,",
				"          nro_control as integer,",
				"          semana_gestacion as integer,",
				"          peso_madre_kg as decimal(5,2),",
				"          presion_arterial as string,",
				"          resultado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: 'SELECT\\n    CAST(control_id AS VARCHAR(50))                 AS control_id,\\n    ci_beneficiaria,\\n    establecimiento_id,\\n    fecha_control,\\n    1                                                AS sistema_key,\\n    nro_control,\\n    semana_gestacion,\\n    peso_madre_kg,\\n    presion_arterial,\\n    CAST(NULL AS VARCHAR(100))                      AS resultado\\nFROM silver.sup_controles_prenatales\\n\\nUNION ALL\\n\\nSELECT\\n    CAST(control_id AS VARCHAR(50))                 AS control_id,\\n    ci_beneficiaria,\\n    CAST(NULL AS VARCHAR(20))                       AS establecimiento_id,\\n    fecha_control,\\n    2                                                AS sistema_key,\\n    nro_control,\\n    semana_gestacion,\\n    peso_madre_kg,\\n    presion_arterial,\\n    resultado\\nFROM silver.bja_controles_prenatales',",
				"     format: 'query') ~> controlesprenatales",
				"source(output(",
				"          beneficiaria_key as integer,",
				"          ci_beneficiaria as string,",
				"          nombres as string,",
				"          primer_apellido as string,",
				"          segundo_apellido as string,",
				"          nombre_completo as string,",
				"          municipio as string,",
				"          departamento as string,",
				"          en_sup as boolean,",
				"          en_bja as boolean,",
				"          en_spl as boolean",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> dimbeneficiaria",
				"source(output(",
				"          establecimiento_key as integer,",
				"          establecimiento_id as string,",
				"          codigo_snis as string,",
				"          nombre as string,",
				"          tipo as string,",
				"          nivel_atencion as string,",
				"          municipio as string,",
				"          departamento as string,",
				"          red_salud as string,",
				"          sistema_origen as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> dimestablecimiento",
				"derivedColumn2, dimbeneficiaria lookup(derivedColumn2@ci_beneficiaria == dimbeneficiaria@ci_beneficiaria,",
				"     multiple: false,",
				"     pickup: 'any',",
				"     broadcast: 'auto')~> lookup1",
				"lookup1, dimestablecimiento lookup(controlesprenatales@establecimiento_id == dimestablecimiento@establecimiento_id,",
				"     multiple: false,",
				"     pickup: 'any',",
				"     broadcast: 'auto')~> lookup2",
				"lookup2 derive(tiempo_key = toInteger(toString(fecha_control, 'yyyyMMdd'))) ~> derivedColumn1",
				"derivedColumn1 select(mapColumn(",
				"          control_id,",
				"          sistema_key,",
				"          nro_control,",
				"          semana_gestacion,",
				"          peso_madre_kg,",
				"          presion_arterial,",
				"          resultado,",
				"          beneficiaria_key,",
				"          ci_beneficiaria = dimbeneficiaria@ci_beneficiaria,",
				"          nombres,",
				"          primer_apellido,",
				"          segundo_apellido,",
				"          nombre_completo,",
				"          municipio = dimbeneficiaria@municipio,",
				"          departamento = dimbeneficiaria@departamento,",
				"          en_sup,",
				"          en_bja,",
				"          en_spl,",
				"          establecimiento_key,",
				"          establecimiento_id = dimestablecimiento@establecimiento_id,",
				"          codigo_snis,",
				"          nombre,",
				"          tipo,",
				"          nivel_atencion,",
				"          municipio = dimestablecimiento@municipio,",
				"          departamento = dimestablecimiento@departamento,",
				"          red_salud,",
				"          sistema_origen,",
				"          tiempo_key",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"controlesprenatales derive(ci_beneficiaria = upper(replace(replace(trim(ci_beneficiaria), '-', ''), ' ', ''))) ~> derivedColumn2",
				"select1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          control_key as integer,",
				"          control_id as string,",
				"          beneficiaria_key as integer,",
				"          establecimiento_key as integer,",
				"          tiempo_key as integer,",
				"          sistema_key as integer,",
				"          nro_control as integer,",
				"          semana_gestacion as integer,",
				"          peso_madre_kg as decimal(5,2),",
				"          presion_arterial as string,",
				"          resultado as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> sink1"
			]
		}
	}
}